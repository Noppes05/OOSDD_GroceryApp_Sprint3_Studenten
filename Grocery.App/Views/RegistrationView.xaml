<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Grocery.App.Views.RegistrationView"
             Title="RegistrationView">
    <StackLayout Padding="50" VerticalOptions="Center">
        <Label Text="Register" FontSize="24" HorizontalOptions="Center" />
        <Entry Placeholder="Name" Text="{Binding Name}" />
        <Entry Placeholder="Email" Margin="0,10,0,0" Text="{Binding Email}" Keyboard="Email" />
        <Entry Placeholder="Password" Margin="0,10,0,0" Text="{Binding Password}" IsPassword="True" />
        <Label Text="{Binding RegistrationMessage}" TextColor="Red" />
        <Button Text="Registreren" Margin="0,10,0,0" Command="{Binding RegisterCommand}" />
        <Button  Text="Ga naar Login"
                 Margin="0,20,0,0"
        Command="{Binding NavigateToLoginCommand}"/>
    </StackLayout>
</ContentPage>